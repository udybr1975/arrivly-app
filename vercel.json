{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron-checkout-reminder", "schedule": "0 6 * * *" },
    { "path": "/api/cron-trial-ending", "schedule": "0 8 * * *" },
    { "path": "/api/cron-sync-ical", "schedule": "0 2 * * *" },
    { "path": "/api/cron-refresh-guides", "schedule": "0 3 1 * *" },
    { "path": "/api/cron-refresh-events", "schedule": "0 4 * * *" },
    { "path": "/api/cron-refresh-experiences", "schedule": "0 5 * * *" },
    { "path": "/api/cron-cleanup-messages", "schedule": "0 5 * * *" },
    { "path": "/api/cron-demo-expiry", "schedule": "0 * * * *" },
    { "path": "/api/cron-demo-purge", "schedule": "0 7 * * *" }
  ]
}

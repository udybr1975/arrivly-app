STRIPE_PRICE_TIER_2=
STRIPE_PRICE_TIER_3=
CRON_SECRET=
NTFY_URL=
# Demo entry flow (public config). OFF unless exactly 'true'. Set in Vercel to go live.
VITE_DEMO_ENABLED=
# Public Cloudflare Turnstile site key (safe to expose). If unset, the /demo captcha
# widget is skipped. NOTE: demo fresh-create now verifies the token server-side and is
# fail-closed, so BOTH this and TURNSTILE_SECRET_KEY must be set to exercise fresh-create
# (the step-1 OTP captcha is the only part that tolerates a missing token). MUST be set
# in production.
VITE_TURNSTILE_SITE_KEY=
# Server-only Cloudflare Turnstile SECRET (NO VITE_ prefix). Verifies the demo
# fresh-create token server-side (fail-closed if unset → every create 403s). MUST be set
# in production.
TURNSTILE_SECRET_KEY=
# Social sign-in via Supabase OAuth. Buttons appear only when exactly 'true'. Configure providers in Supabase first.
VITE_SOCIAL_AUTH=
# Apple button gate. Leave blank until Apple Sign in is configured; then set to 'true'.
VITE_SOCIAL_APPLE=
